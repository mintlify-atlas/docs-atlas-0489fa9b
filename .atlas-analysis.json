  "keyFeatures": [
    "Adaptive accessibility profiles: automatic detection of user needs (screen reader, large text, high contrast, voice feedback)",
    "AI nudging engine: real-time detection of user difficulty on each screen to offer contextual assistance",
    "Fraud and transaction risk scoring with explainable risk factors",
    "Open Finance integrations: connect and sync external bank accounts",
    "Microservices architecture with Ocelot API Gateway and JWT authentication",
    "SPEI-based transfers and ledger management",
    "Accessibility wizard (WizardView) for onboarding users into their preferred UI mode",
    "Analytics event tracking for measuring accessibility impact"
  ],
